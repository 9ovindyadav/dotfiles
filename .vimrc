set number
set relativenumber
set cursorline
set mouse=a
set clipboard=unnamedplus

syntax on
colorscheme desert

set tabstop=4
set shiftwidth=4
set expandtab
set smartindent

set incsearch
set hlsearch
set ignorecase
set smartcase

set showmatch
set showcmd
set laststatus=2
set wildmenu
set cmdheight=1
set ttyfast
set noerrorbells
set autoread

set foldmethod=indent
set foldlevel=99
